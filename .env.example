# Database Connection (Neon PostgreSQL or similar)
DATABASE_URL="postgresql://user:password@localhost:5432/lahbabiguide?schema=public"

# Google Gemini API Credentials
GEMINI_API_KEY=

# NextAuth configuration
AUTH_SECRET="your-auth-secret-min-32-characters"
NEXTAUTH_URL="http://localhost:3000"

# Storage Configuration (Adapter-based)
# STORAGE_TYPE options: "vercel-blob" | "s3" | "local"
STORAGE_TYPE="vercel-blob"
BLOB_READ_WRITE_TOKEN=""

# S3 Configuration (Required if STORAGE_TYPE="s3")
S3_REGION=""
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_BUCKET=""
S3_ENDPOINT="" # Required for MinIO, Cloudflare R2, or DigitalOcean Spaces

# CMS & SEO
SITE_URL="https://lahbabiguide.com"
REVALIDATE_TOKEN="secure-token-for-manual-revalidation"

# Stripe (optional, enables paid product checkout)
STRIPE_SECRET_KEY=""
NEXT_PUBLIC_SITE_URL="https://lahbabiguide.com"
